{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["./saia-gwdg-plugin.js"],
  "provider": {
    "saia-gwdg": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://chat-ai.academiccloud.de/v1"
      }
    }
  },
  "agent": {
    "plan": {
      "color": "warning"
    },
    "auto": {
      "description": "Orchestrator: plan → implement → validate loop (max 1 fix round)",
      "mode": "primary",
      "model": "saia-gwdg/deepseek-v4-flash",
      "temperature": 0.2,
      "steps": 12,
      "prompt": "{file:./prompts/auto.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "write": "deny",
        "task": {
          "auto-quick": "allow",
          "researcher": "allow",
          "coder": "allow",
          "debugger": "allow"
        }
      }
    },
    "coder": {
      "description": "Implementation agent: executes an audited PLAN, returns CHANGES block",
      "mode": "subagent",
      "model": "saia-gwdg/qwen3-coder-next",
      "temperature": 0.2,
      "steps": 20,
      "prompt": "{file:./prompts/coder.md}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "write": "allow"
      }
    },
    "researcher": {
      "description": "Read-only analyst: produces PLAN blocks with runnable acceptance criteria",
      "mode": "subagent",
      "model": "saia-gwdg/qwen3.5-122b-a10b",
      "temperature": 0.2,
      "steps": 8,
      "prompt": "{file:./prompts/researcher.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "deny"
      }
    },
    "auto-quick": {
      "description": "Fast path for trivial tasks (typos, single-file changes): implements directly without researcher phase",
      "mode": "subagent",
      "model": "saia-gwdg/deepseek-v4-flash",
      "temperature": 0.2,
      "steps": 6,
      "prompt": "You implement single-file, fully-specified tasks quickly. No research phase needed.\n\nYou MUST output a CHANGES block and you MUST self-check (run one command):\n\n```\n## CHANGES\nSTATUS: COMPLETE | BLOCKED\nFILES TOUCHED:\n- <path> — <summary>\nSELF-CHECK: <command run and result>\n```",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "write": "allow"
      }
    },
    "debugger": {
      "description": "Validator: runs acceptance criteria, returns VERDICT PASS/FAIL with quoted output",
      "mode": "subagent",
      "model": "saia-gwdg/qwen3.5-122b-a10b",
      "temperature": 0.1,
      "steps": 12,
      "prompt": "{file:./prompts/debugger.md}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "write": "allow"
      }
    }
  }
}
